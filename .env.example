# MySQL pool size (default 10). After message:send SQL reductions, 15–20 is
# reasonable under concurrent load — tune from metrics.
# DB_POOL_SIZE=15

# # MySQL Configuration
# DB_HOST=163.123.183.89
# DB_PORT=17705
# DB_NAME=alanyaBD2026
# DB_USER=trump
# DB_PASSWORD=Kendra2026

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=

# Firebase Service Account (JSON stringified)
FIREBASE_SERVICE_ACCOUNT=

# FCM - Uses Firebase Admin SDK HTTP v1 (via FIREBASE_SERVICE_ACCOUNT)
# No FCM_SERVER_KEY needed (old method, less secure)

# TURN / ICE (GET /api/turn/credentials)
# auth: "static" = username/credential du JSON ; "auth": "hmac" = credentials éphémères via TURN_SECRET
# TURN_SECRET=
# TURN_TTL_SEC=86400
# TURN_SERVERS=[{"urls":["turn:example.com:3478"],"username":"user","credential":"pass","auth":"static"},{"urls":["stun:coturn.example:3478","turn:coturn.example:3478?transport=udp","turns:coturn.example:5349?transport=tcp"],"auth":"hmac"}]
